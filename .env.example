# Copy to .env.local and fill from Firebase Console → Project settings → Your apps (Web).
# WRONG: pasting the JS object (apiKey: "...", authDomain: "...") — CRA will ignore it.
# RIGHT: one line per variable, REACT_APP_ prefix, NO commas:
#   REACT_APP_FIREBASE_API_KEY=yourKeyHere
# Restart npm start after editing.

REACT_APP_FIREBASE_API_KEY=
REACT_APP_FIREBASE_AUTH_DOMAIN=
REACT_APP_FIREBASE_PROJECT_ID=
REACT_APP_FIREBASE_APP_ID=
REACT_APP_FIREBASE_STORAGE_BUCKET=
REACT_APP_FIREBASE_MESSAGING_SENDER_ID=
